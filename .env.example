# Copy this file to .env.local and fill in real values before running locally.

# Neon Postgres connection strings — get these from your Neon project dashboard
# (neon.tech -> your project -> Connection Details).
# DATABASE_URL: pooled connection (used by the app at runtime)
# DIRECT_URL: direct connection (used by Prisma for migrations)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/adspark?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/adspark?sslmode=require"

# Get a free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret

# Local dev URL; set to your deployed URL in production (e.g. Vercel dashboard)
NEXTAUTH_URL=http://localhost:3000
